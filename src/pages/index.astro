<style>
  /* ================================================================
     HERO — The signature moment.
     Giant ghosted type behind a composited pizza photograph.
     Dark hero on a light site for contrast and drama.
     ================================================================ */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-ink);
    color: var(--color-cream);
    padding-bottom: var(--space-2xl);
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    display: none;
    flex-direction: column;
    align-items: center;
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .hero-bg-text {
      display: flex;
    }
  }

  .hero-bg-line {
    font-family: var(--f-display);
    font-weight: 900;
    font-style: italic;
    font-size: clamp(6rem, 22vw, 20rem);
    color: transparent;
    -webkit-text-stroke: 1px oklch(0.4 0.02 55 / 0.3);
    white-space: nowrap;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: end;
    padding-top: 6rem;
  }

  .hero-image-frame {
    position: relative;
    justify-self: center;
    max-width: 500px;
    width: 100%;

    &::before {
      content: '';
      position: absolute;
      inset: -12px;
      border: 1px solid oklch(0.5 0.08 35 / 0.2);
      pointer-events: none;
    }
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center 40%;
    filter: contrast(1.05) saturate(1.1);
  }

  .hero-text {
    max-width: 480px;
  }

  .hero-h1 {
    font-family: var(--f-display);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    font-style: italic;
    color: var(--color-terracotta-light);
    margin-bottom: 0.25rem;
  }

  .hero-location {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-stone);
    margin-bottom: var(--space-md);
  }

  .hero-description {
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.15rem);
    color: oklch(0.78 0.02 70);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;

    & .btn-outline {
      color: var(--color-cream);
      border-color: var(--color-cream);

      &:hover {
        background: var(--color-cream);
        color: var(--color-ink);
      }
    }
  }

  .hero-scroll-cue {
    position: absolute;
    bottom: 2rem;
    right: var(--container-pad);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 3;

    & span {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-stone);
      writing-mode: vertical-rl;
    }
  }

  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--color-terracotta), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
    }

    .hero-scroll-cue {
      display: flex;
    }

    .hero-content {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-2xl);
      padding-top: 20vh;
    }

    .hero-image-frame {
      max-width: none;
    }
  }

  @media (min-width: 1100px) {
    .hero-bg-line {
      -webkit-text-stroke: 1.5px oklch(0.4 0.02 55 / 0.25);
    }
  }

  /* ================================================================
     INTRO
     ================================================================ */
  .intro {
    padding-block: var(--space-3xl);
    background: var(--color-white);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .intro-text {
    & .divider {
      margin-bottom: var(--space-md);
    }

    & h2 {
      font-family: var(--f-display);
      font-size: clamp(1.8rem, 3vw + 0.5rem, 2.8rem);
      font-weight: 500;
      font-style: italic;
      line-height: 1.2;
      color: var(--color-ink);
      margin-bottom: var(--space-md);
      text-wrap: balance;
