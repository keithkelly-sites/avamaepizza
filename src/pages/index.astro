      object-fit: cover;
      object-position: center 30%;
      filter: contrast(1.05) saturate(1.05);
    }

    &::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        oklch(0.97 0.01 80 / 0.15) 0%,
        transparent 50%
      );
      pointer-events: none;
    }
  }

  @media (min-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  /* ================================================================
     MENU
     ================================================================ */
  .menu-section {
    padding-block: var(--space-3xl);
    background: var(--color-linen);
  }

  .section-header {
    text-align: center;
