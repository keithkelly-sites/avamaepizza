  }

  /* ================================================================
     LOCATION
     ================================================================ */
  .location-section {
    padding-block: var(--space-3xl);
    background: var(--color-cream);
  }

  .location-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .location-text {
    & h2 {
      font-family: var(--f-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
