  .menu-item-desc {
    font-size: 0.85rem;
    color: var(--color-stone);
    margin-top: 0.15rem;
    padding-left: 0.25rem;
  }

  .menu-dressings {
    font-size: 0.8rem;
    color: var(--color-stone);
    font-style: italic;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid oklch(0.25 0.01 55 / 0.1);
  }


  .menu-footer {
    text-align: center;
    padding-top: var(--space-xl);

    & p {
      font-size: 0.8rem;
      color: var(--color-stone);
      max-width: 50ch;
      margin-inline: auto;
      margin-bottom: var(--space-md);
    }
