    padding-bottom: 0.5rem;
    border-bottom: 1px solid oklch(0.25 0.01 55 / 0.1);
  }

  .menu-items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .menu-item-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .menu-item-name {
    font-family: var(--f-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .menu-item-dots {
    flex: 1;
    border-bottom: 1px dotted oklch(0.25 0.01 55 / 0.2);
    min-width: 20px;
    margin-bottom: 4px;
  }

  .menu-item-price {
    font-family: var(--f-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-terracotta-light);
