        oklch(0.95 0.015 75 / 0.15),
        transparent 40%
      );
      pointer-events: none;
    }
  }

  .family-text {
    & h2 {
      font-family: var(--f-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 500;
      font-style: italic;
      color: var(--color-ink);
      margin-bottom: var(--space-md);
