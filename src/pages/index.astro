    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;

    & a {
      color: var(--color-stone);
      transition: color 0.3s;
      &:hover { color: var(--color-ink); }
    }
  }

  .location-social-sep {
    color: oklch(0.25 0.01 55 / 0.2);
  }

